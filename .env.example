# ---- Gemini (required ONLY for the /v1/agent google-adk pipeline) ----
# The deterministic engine and /v1/discover|scout|profile run with no key.
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
CODAS_GEMINI_MODEL=gemini-3.5-flash
CODAS_GEMINI_MODELS=gemini-3.5-flash,gemini-3.1-pro-preview

# ---- Service auth ----
# Comma-separated API keys (rotate by listing old+new). Unset = localhost-only access.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CODAS_AGENT_API_KEYS=
# Explicit CORS origins (comma-separated). Empty = no cross-origin browser access.
CODAS_CORS_ORIGINS=

# ---- Engine knobs ----
# Bootstrap/permutation depth (higher = tighter, slower). Default 1000.
CODAS_VALIDATION_RESAMPLES=1000
# Max decoded size of an inline CSV per request (MB).
CODAS_AGENT_MAX_INLINE_CSV_MB=50
# Floor on resamples for a single request so a "fast" run stays meaningful.
CODAS_AGENT_MIN_RESAMPLES=100
